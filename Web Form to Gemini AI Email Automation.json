      "id": "17b130b8-419e-4500-b94f-60364871e228",
      "name": "Generate Progress Report",
      "type": "@n8n/n8n-nodes-langchain.googleGemini",
      "typeVersion": 1.2,
      "position": [
        688,
        304
      ]
    },
    {
      "parameters": {
        "jsCode": "const response = $input.first().json.response;\nlet reportData;\n\ntry {\n  // Try to parse as JSON directly\n  reportData = JSON.parse(response);\n} catch (e) {\n  // If it fails, try to extract JSON from markdown code blocks\n  const jsonMatch = response.match(/```(?:json)?\\s*([\\s\\S]*?)```/);\n  if (jsonMatch) {\n    reportData = JSON.parse(jsonMatch[1].trim());\n  } else {\n    // Try to find JSON object in the text\n    const objectMatch = response.match(/\\{[\\s\\S]*\\}/);\n    if (objectMatch) {\n      reportData = JSON.parse(objectMatch[0]);\n    } else {\n      throw new Error(\"Could not parse JSON from response\");\n    }\n  }\n}\n\nreturn [{ json: reportData }];"
      },
      "id": "ee2369b1-0919-429b-a2ad-84da1a299d8d",
      "name": "Parse JSON Report",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1040,
        304
      ]
    },
    {
      "parameters": {
        "assignments": {
          "assignments": [
            {
              "id": "1",
              "name": "emailSubject",
              "value": "=Construction Progress Report - {{ $json.site_name }} - {{ $json.report_date }}",
              "type": "string"
            },
            {
              "id": "2",
              "name": "emailBody",
              "value": "=<!DOCTYPE html>\n<html>\n<head>\n<style>\nbody { font-family: Arial, sans-serif; line-height: 1.6; color: #333; }\n.header { background-color: #2c3e50; color: white; padding: 20px; text-align: center; }\n.content { padding: 20px; }\n.section { margin-bottom: 20px; }\n.section-title { font-weight: bold; color: #2c3e50; margin-bottom: 5px; }\n.highlight { background-color: #f8f9fa; padding: 10px; border-left: 4px solid #3498db; }\n.footer { background-color: #ecf0f1; padding: 15px; text-align: center; font-size: 12px; color: #7f8c8d; }\n</style>\n</head>\n<body>\n<div class=\"header\">\n<h1>Daily Construction Progress Report</h1>\n</div>\n<div class=\"content\">\n<div class=\"section\">\n<div class=\"section-title\">Site Information</div>\n<p><strong>Site Name:</strong> {{ $json.site_name }}</p>\n<p><strong>Report Date:</strong> {{ $json.report_date }}</p>\n</div>\n<div class=\"section highlight\">\n<div class=\"section-title\">Work Observed</div>\n<p>{{ $json.work_observed }}</p>\n</div>\n<div class=\"section\">\n<div class=\"section-title\">Progress Summary</div>\n<p>{{ $json.progress_summary }}</p>\n<p><strong>Estimated Completion:</strong> {{ $json.estimated_completion_percentage }}</p>\n</div>\n<div class=\"section\">\n<div class=\"section-title\">Materials Observed</div>\n<p>{{ $json.materials_observed }}</p>\n</div>\n<div class=\"section\">\n<div class=\"section-title\">Safety Observation</div>\n<p>{{ $json.safety_observation }}</p>\n</div>\n<div class=\"section\">\n<div class=\"section-title\">Issues or Risks</div>\n<p>{{ $json.issues_or_risks }}</p>\n</div>\n<div class=\"section\">\n<div class=\"section-title\">Next Recommended Step</div>\n<p>{{ $json.next_recommended_step }}</p>\n</div>\n<div class=\"section highlight\">\n<div class=\"section-title\">Client Summary</div>\n<p>{{ $json.client_summary }}</p>\n</div>\n</div>\n<div class=\"footer\">\n<p>This report was automatically generated by the Construction Progress Reporting System</p>\n</div>\n</body>\n</html>",
              "type": "string"
            }
          ]
        },
        "includeOtherFields": true,
        "options": {}
      },
